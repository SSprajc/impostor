rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Validates the shape of an approved word-pair document.
    // The app writes exactly these three fields; anything else is rejected.
    function isValidWordPair() {
      return request.resource.data.keys().hasOnly(
               ['civilianWord', 'impostorWord', 'gameMode'])
          && request.resource.data.civilianWord is string
          && request.resource.data.civilianWord.size() > 0
          && request.resource.data.civilianWord.size() <= 50
          && request.resource.data.impostorWord is string
          && request.resource.data.impostorWord.size() > 0
          && request.resource.data.impostorWord.size() <= 50
          && request.resource.data.gameMode in ['clueless', 'insidious'];
    }

    // Approved word pairs from the quality-check dialog.
    // Write-only collection: the app has no Firebase Auth, so these writes are
    // necessarily unauthenticated. Reads are disabled until enough pairs are
    // collected (see CLAUDE.md). Shape validation limits abuse.
    match /word_pairs/{pairId} {
      allow read, delete: if false;
      allow create, update: if isValidWordPair();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
